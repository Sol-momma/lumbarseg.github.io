---
import "../styles/site.css";

interface Props {
  title: string;
  description: string;
  language?: "ja" | "en";
  page?: "memo" | "notes";
}

const { title, description, language = "en", page = "memo" } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const homeHref = baseUrl;
const englishHref = baseUrl;
const japaneseHref = `${baseUrl}ja/`;
const notesHref = `${baseUrl}notes/`;
const heroImage = `${baseUrl}images/lumbarseg-hero.png`;
const paperPdf = `${baseUrl}papers/paper.pdf`;

const copy = {
  en: {
    htmlLang: "en",
    nav: {
      overview: "Overview",
      workflow: "Workflow",
      method: "Method",
      results: "Results",
      resources: "Resources",
      plan: "Plan",
      japanese: "日本語",
      notes: "Study Notes",
    },
    hero: {
      venue: "Research Project",
      title: "LumbarSeg",
      subtitle: "Four-Class Lumbar MRI Segmentation",
      badge: "Modified U-Net / Ahmed et al. 2025",
      authors: "Paper memo and reproduction plan for lumbar spine MRI segmentation",
      affiliation: "SPIDER dataset · T2 SPACE · Combined Loss",
      footnote: "Reorganized for presentation preparation and implementation planning.",
      links: {
        paper: "Paper PDF",
        source: "ScienceDirect",
        dataset: "Dataset PDF",
        notes: "Study Notes",
      },
      tldr:
        "TL;DR: LumbarSeg reformulates lumbar MRI segmentation as a four-class pixel classification task and reports Dice scores around 0.97 on high-resolution T2 SPACE scans.",
    },
  },
  ja: {
    htmlLang: "ja",
    nav: {
      overview: "概要",
      workflow: "ワークフロー",
      method: "手法",
      results: "結果",
      resources: "資料",
      plan: "計画",
      japanese: "日本語",
      notes: "学習メモ",
    },
    hero: {
      venue: "Research Project",
      title: "LumbarSeg",
      subtitle: "腰椎MRIを4クラスに自動分割する研究",
      badge: "Modified U-Net / Ahmed et al. 2025",
      authors: "腰椎MRIセグメンテーション論文の発表準備・実装メモ",
      affiliation: "SPIDER dataset · T2 SPACE · Combined Loss",
      footnote: "論文理解、再現実装、卒研計画のために再整理したページ。",
      links: {
        paper: "論文PDF",
        source: "ScienceDirect",
        dataset: "Dataset PDF",
        notes: "学習メモ",
      },
      tldr:
        "TL;DR: LumbarSeg は腰椎MRIを背景・椎体・脊柱管・椎間板の4クラスに分割する問題として整理し、T2 SPACE で約0.97のDiceを報告している。",
    },
  },
} as const;

const t = copy[language];
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar" aria-label="Site navigation">
      <a class="brand-link" href={homeHref}>LumbarSeg</a>
      <nav>
        <a href="#overview">{t.nav.overview}</a>
        <a href="#data">{t.nav.workflow}</a>
        <a href="#model">{t.nav.method}</a>
        <a href="#metrics">{t.nav.results}</a>
        <a href="#resources">{t.nav.resources}</a>
        <a href={notesHref}>{t.nav.notes}</a>
        {
          language === "en" ? (
            <a class="language-link" href={japaneseHref}>
              {t.nav.japanese}
            </a>
          ) : (
            <a class="language-link" href={englishHref}>
              English
            </a>
          )
        }
      </nav>
    </header>

    <main>
      <section class="hero" id="overview">
        <div class="hero-inner">
          <p class="venue">{t.hero.venue}</p>
          <h1>{t.hero.title}</h1>
          <h2>{t.hero.subtitle}</h2>
          <p class="paper-badge">{t.hero.badge}</p>
          <p class="authors">{t.hero.authors}</p>
          <p class="affiliation">{t.hero.affiliation}</p>
          <p class="author-note">{t.hero.footnote}</p>

          <div class="publication-links" aria-label="Publication links">
            <a class="button" href={paperPdf} target="_blank" rel="noopener noreferrer">
              {t.hero.links.paper}
            </a>
            <a
              class="button"
              href="https://www.sciencedirect.com/science/article/pii/S2666827025000180"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t.hero.links.source}
            </a>
            <a
              class="button"
              href={`${baseUrl}papers/Dataset_Paper.pdf`}
              target="_blank"
              rel="noopener noreferrer"
            >
              {t.hero.links.dataset}
            </a>
            {page === "memo" && <a class="button" href={notesHref}>{t.hero.links.notes}</a>}
          </div>
        </div>

        <figure class="hero-figure">
          <img
            src={heroImage}
            alt="Lumbar MRI segmentation visualization"
            width="1536"
            height="864"
            loading="eager"
          />
        </figure>

        <p class="tldr-box">{t.hero.tldr}</p>
      </section>

      <slot />
    </main>

    <script>
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("visible");
          });
        },
        { threshold: 0.12 },
      );

      document
        .querySelectorAll(".reveal")
        .forEach((node) => revealObserver.observe(node));

      const search = document.querySelector("#termSearch");
      const terms = [...document.querySelectorAll(".term")];
      search?.addEventListener("input", () => {
        const query = search.value.trim().toLowerCase();
        terms.forEach((term) => {
          const text =
            `${term.getAttribute("data-term")} ${term.textContent}`.toLowerCase();
          term.hidden = query.length > 0 && !text.includes(query);
        });
      });
    </script>
    <script src={`${baseUrl}baseline-showcase.js`}></script>
  </body>
</html>
