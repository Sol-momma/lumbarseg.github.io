---
import SpineVisual from "../components/SpineVisual.astro";
import "../styles/site.css";

interface Props {
  title: string;
  description: string;
  language?: "ja" | "en";
  page?: "memo" | "notes";
}

const { title, description, language = "ja", page = "memo" } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const homeHref = baseUrl;
const englishHref = `${baseUrl}en/`;
const notesHref = `${baseUrl}notes/`;

const copy = {
  ja: {
    htmlLang: "ja",
    brand: ["LumbarSeg", "腰椎MRI解析"],
    navLabel: "ページ内ナビゲーション",
    pageLinks: {
      memo: { href: homeHref, label: "論文メモ" },
      notes: { href: notesHref, label: "学習メモ" },
    },
    pages: {
      memo: {
        note: "Ahmed et al. (2025) の内容を、発表準備と実装メモ用に再整理したページ。",
        eyebrow: "Ahmed et al. 2025 / Modified U-Net",
        title: "LumbarSeg: 腰椎MRIを4クラスに自動分割する研究",
        lead: "MRI画像から背景・椎体・脊柱管・椎間板をピクセル単位で分類する。論文の核心は、前処理、U-Net改良、Combined Lossを組み合わせて高精度なセグメンテーションを実現した点にある。",
        actions: {
          primary: "重要情報を見る",
          resources: "PDFとURLを見る",
          glossary: "難しい単語を確認",
          notes: "学習メモへ",
        },
        navItems: [
          { id: "overview", label: "概要" },
          { id: "resources", label: "資料" },
          { id: "important", label: "重要情報" },
          { id: "data", label: "データと前処理" },
          { id: "model", label: "モデル" },
          { id: "experiments", label: "実験" },
          { id: "metrics", label: "精度" },
          { id: "glossary", label: "用語" },
          { id: "todo", label: "卒研メモ" },
        ],
      },
      notes: {
        note: "論文を理解しながら、自分の言葉で疑問・気づき・次の行動を残すためのページ。",
        eyebrow: "Study Notes / Understanding First",
        title: "理解を深めるための研究メモ",
        lead: "このページは、論文の内容やノートブックの処理を自分で説明できるようにするための記録場所。完成原稿ではなく、理解の途中経過を残すために使う。",
        actions: {
          primary: "今の焦点を見る",
          resources: "論文メモへ戻る",
          glossary: "曖昧な点を見る",
          notes: "学習メモへ",
        },
        navItems: [
          { id: "overview", label: "概要" },
          { id: "focus", label: "今の焦点" },
          { id: "understanding", label: "理解メモ" },
          { id: "questions", label: "曖昧な点" },
          { id: "log", label: "実験ログ" },
          { id: "next", label: "次にやること" },
        ],
      },
    },
  },
  en: {
    htmlLang: "en",
    brand: ["LumbarSeg", "MRI Segmentation"],
    navLabel: "Page navigation",
    pageLinks: {
      memo: { href: homeHref, label: "Paper Memo" },
      notes: { href: notesHref, label: "Study Notes" },
    },
    pages: {
      memo: {
        note: "English presentation version of the Ahmed et al. (2025) paper memo.",
        eyebrow: "Ahmed et al. 2025 / Modified U-Net",
        title: "LumbarSeg: Four-Class Lumbar MRI Segmentation",
        lead: "This page summarizes a deep learning approach that classifies each MRI pixel into background, vertebrae, spinal canal, or intervertebral discs. The key idea is the combination of careful preprocessing, a modified U-Net, and a Combined Loss.",
        actions: {
          primary: "Key facts",
          resources: "PDF and links",
          glossary: "Terminology",
          notes: "Study notes",
        },
        navItems: [
          { id: "overview", label: "Overview" },
          { id: "resources", label: "Sources" },
          { id: "important", label: "Key Facts" },
          { id: "data", label: "Data Pipeline" },
          { id: "model", label: "Model" },
          { id: "experiments", label: "Experiment" },
          { id: "metrics", label: "Metrics" },
          { id: "glossary", label: "Terms" },
          { id: "todo", label: "Project Plan" },
        ],
      },
      notes: {
        note: "A workspace for questions, understanding notes, and next actions while reading the paper.",
        eyebrow: "Study Notes / Understanding First",
        title: "Research Notes for Learning",
        lead: "Use this page to write what you understand, what still feels unclear, and what you want to check next. It is meant to support learning, not polished presentation output.",
        actions: {
          primary: "Current focus",
          resources: "Back to memo",
          glossary: "Open questions",
          notes: "Study notes",
        },
        navItems: [
          { id: "overview", label: "Overview" },
          { id: "focus", label: "Current Focus" },
          { id: "understanding", label: "Understanding" },
          { id: "questions", label: "Questions" },
          { id: "log", label: "Log" },
          { id: "next", label: "Next Actions" },
        ],
      },
    },
  },
} as const;

const t = copy[language];
const pageCopy = t.pages[page];
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="progress" aria-hidden="true"></div>
    <div class="shell">
      <aside class="sidebar" aria-label={t.navLabel}>
        <div class="brand">
          <small>Research Project</small>
          <strong>{t.brand[0]}<br />{t.brand[1]}</strong>
        </div>
        <div class="page-links" aria-label="Page switcher">
          <a
            class:list={["page-link", { active: page === "memo" }]}
            href={t.pageLinks.memo.href}
          >
            {t.pageLinks.memo.label}
          </a>
          <a
            class:list={["page-link", { active: page === "notes" }]}
            href={t.pageLinks.notes.href}
          >
            {t.pageLinks.notes.label}
          </a>
        </div>
        <div class="language-tabs" aria-label="Language switcher">
          <a
            class:list={["language-tab", { active: language === "ja" }]}
            href={homeHref}>日本語</a
          >
          <a
            class:list={["language-tab", { active: language === "en" }]}
            href={englishHref}>English</a
          >
        </div>
        <ol class="nav">
          {
            pageCopy.navItems.map((item, index) => (
              <li>
                <a href={`#${item.id}`}>
                  {item.label}
                  <span>{String(index + 1).padStart(2, "0")}</span>
                </a>
              </li>
            ))
          }
        </ol>
        <p class="sidebar-note">
          {pageCopy.note}
        </p>
      </aside>

      <main>
        <header class="hero" id="overview">
          <div class="reveal">
            <span class="eyebrow">{pageCopy.eyebrow}</span>
            <h1>{pageCopy.title}</h1>
            <p class="lead">{pageCopy.lead}</p>
            <div class="hero-actions">
              <a
                class="button primary"
                href={page === "memo" ? "#important" : "#focus"}
                >{pageCopy.actions.primary}</a
              >
              <a class="button" href={page === "memo" ? "#resources" : homeHref}
                >{pageCopy.actions.resources}</a
              >
              <a
                class="button"
                href={page === "memo" ? "#glossary" : "#questions"}
                >{pageCopy.actions.glossary}</a
              >
              {
                page === "memo" && (
                  <a class="button" href={notesHref}>
                    {pageCopy.actions.notes}
                  </a>
                )
              }
            </div>
          </div>
          <SpineVisual language={language} />
        </header>

        <slot />
      </main>
    </div>

    <script>
      const progress = document.querySelector(".progress");
      const links = [...document.querySelectorAll(".nav a")];
      const sections = links
        .map((link) => document.querySelector(link.getAttribute("href") || ""))
        .filter(Boolean);

      function updateProgress() {
        const max = document.documentElement.scrollHeight - innerHeight;
        const ratio = max > 0 ? scrollY / max : 0;
        if (progress) {
          progress.style.width = `${Math.min(100, Math.max(0, ratio * 100))}%`;
        }
      }

      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = `#${entry.target.id}`;
            links.forEach((link) =>
              link.classList.toggle("active", link.getAttribute("href") === id),
            );
          });
        },
        { rootMargin: "-35% 0px -55% 0px", threshold: 0.01 },
      );

      sections.forEach((section) => sectionObserver.observe(section));

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("visible");
          });
        },
        { threshold: 0.12 },
      );

      document
        .querySelectorAll(".reveal")
        .forEach((node) => revealObserver.observe(node));

      const search = document.querySelector("#termSearch");
      const terms = [...document.querySelectorAll(".term")];
      search?.addEventListener("input", () => {
        const query = search.value.trim().toLowerCase();
        terms.forEach((term) => {
          const text =
            `${term.getAttribute("data-term")} ${term.textContent}`.toLowerCase();
          term.hidden = query.length > 0 && !text.includes(query);
        });
      });

      addEventListener("scroll", updateProgress, { passive: true });
      addEventListener("resize", updateProgress);
      updateProgress();
    </script>
    <script src={`${baseUrl}baseline-showcase.js`}></script>
  </body>
</html>
