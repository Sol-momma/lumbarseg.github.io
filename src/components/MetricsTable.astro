---
interface MetricRow {
  structure: string;
  dice: string;
  iou: string;
  meaning: string;
}

interface Props {
  rows: MetricRow[];
}

const { rows } = Astro.props;
---

<table class="result-table">
  <thead>
    <tr>
      <th>構造</th>
      <th>Dice</th>
      <th>IoU</th>
      <th>意味</th>
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          <td>{row.structure}</td>
          <td>
            <span class="score">{row.dice}</span>
            <span class="bar">
              <i style={`--w: ${Number(row.dice) * 100}%`} />
            </span>
          </td>
          <td>{row.iou}</td>
          <td>{row.meaning}</td>
        </tr>
      ))
    }
  </tbody>
</table>
