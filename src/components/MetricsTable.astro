---
interface MetricRow {
  structure: string;
  dice: string;
  iou: string;
  meaning: string;
}

interface Props {
  rows: MetricRow[];
  language?: "ja" | "en";
}

const { rows, language = "ja" } = Astro.props;
const headers =
  language === "en"
    ? ["Structure", "Dice", "IoU", "Interpretation"]
    : ["構造", "Dice", "IoU", "意味"];
---

<table class="result-table">
  <thead>
    <tr>
      {headers.map((header) => <th>{header}</th>)}
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          <td>{row.structure}</td>
          <td>
            <span class="score">{row.dice}</span>
            <span class="bar">
              <i style={`--w: ${Number(row.dice) * 100}%`} />
            </span>
          </td>
          <td>{row.iou}</td>
          <td>{row.meaning}</td>
        </tr>
      ))
    }
  </tbody>
</table>
