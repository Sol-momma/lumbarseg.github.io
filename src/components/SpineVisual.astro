---
interface Props {
  language?: "ja" | "en";
}

const { language = "ja" } = Astro.props;

const labels = {
  ja: {
    vertebrae: "椎体 Vertebrae",
    canal: "脊柱管 Spinal Canal",
    discs: "椎間板 IVDs",
    input: "MRI入力",
    model: "Modified U-Net",
    output: "予測マスク",
    aria: "MRI入力からU-Netを通してセグメンテーションマスクを出力する流れの模式図",
  },
  en: {
    vertebrae: "Vertebrae",
    canal: "Spinal Canal",
    discs: "Intervertebral Discs",
    input: "MRI input",
    model: "Modified U-Net",
    output: "Predicted mask",
    aria: "Pipeline diagram showing MRI input, U-Net inference, and predicted segmentation mask",
  },
} as const;

const t = labels[language];
---

<div class="visual reveal" aria-label={t.aria}>
  <div class="visual-title">T2 SPACE segmentation workflow</div>
  <div class="segmentation-flow">
    <div class="scan-panel">
      <span>{t.input}</span>
      <div class="mri-slice" aria-hidden="true">
        <i class="scan-bone b1"></i>
        <i class="scan-bone b2"></i>
        <i class="scan-bone b3"></i>
        <i class="scan-bone b4"></i>
        <i class="scan-disc d1"></i>
        <i class="scan-disc d2"></i>
        <i class="scan-disc d3"></i>
      </div>
    </div>
    <div class="model-node">
      <strong>{t.model}</strong>
      <small>softmax 4 classes</small>
    </div>
    <div class="scan-panel output-panel">
      <span>{t.output}</span>
      <div class="mri-slice mask-slice" aria-hidden="true">
        <i class="mask vertebra-mask m1"></i>
        <i class="mask vertebra-mask m2"></i>
        <i class="mask vertebra-mask m3"></i>
        <i class="mask canal-mask"></i>
        <i class="mask disc-mask dm1"></i>
        <i class="mask disc-mask dm2"></i>
        <i class="mask disc-mask dm3"></i>
      </div>
    </div>
  </div>
  <div class="legend">
    <span><i class="dot" style="--c: var(--vertebrae)"></i>{t.vertebrae}</span>
    <span><i class="dot" style="--c: var(--canal)"></i>{t.canal}</span>
    <span><i class="dot" style="--c: var(--disc)"></i>{t.discs}</span>
  </div>
</div>
